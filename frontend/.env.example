# ============================================================================
# Frontend Environment Configuration
# ============================================================================

# AWS Cognito Configuration
# Get these values from your CloudFormation stack outputs after deploying the backend
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_AWS_REGION=us-east-1

# Backend API Configuration
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/api

# ============================================================================
# Setup Instructions
# ============================================================================
#
# Option 1: Automatic Setup (Recommended)
# ----------------------------------------
# Run the setup script from the project root, which will:
# - Deploy the backend (optional)
# - Fetch all configuration from CloudFormation
# - Create this .env.local file automatically
#
#   cd .. && ./setup-local-dev.sh
#
# Option 2: Manual Setup
# ----------------------
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Deploy your backend first:
#    cd ../backend && sam build && sam deploy
#
# 3. Get the stack outputs:
#    sam list stack-outputs --stack-name <your-stack-name>
#
# 4. Update .env.local with these values from CloudFormation outputs:
#    - UserPoolId           -> VITE_USER_POOL_ID
#    - UserPoolClientId     -> VITE_USER_POOL_CLIENT_ID
#    - UserPoolRegion       -> VITE_AWS_REGION
#    - BackendApiUrl        -> VITE_API_BASE_URL
#
# 5. Install dependencies and start dev server:
#    npm install
#    npm run dev
#
# ============================================================================
# Deployment
# ============================================================================
#
# To build with backend configuration and deploy to S3/CloudFront:
#   npm run deploy
#
# Or set environment variables manually:
#   BACKEND_STACK_NAME=your-backend-stack npm run deploy
#
# ============================================================================
